{
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "lib": ["esnext", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext"
  },
  "exclude": ["dist"],
  "include": [".astro/types.d.ts", "**/*"]
}
